!**/apk_public.pem
!**/debian_public.pem
!**/usign_public.key
id_rsa
id_ed25519
secrets.h
!secrets.h.example
docker.db.env
.secrets/
credentials.json
*credentials*.json
!*credentials*.example.json


# Claude Code local worktrees/agent state
.claude/
