__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
.eggs/

# PyInstaller / packaging build artifacts
.build/
*.manifest

# Virtual environments
.venv/
venv/
env/
ENV/

# Environment variables
.env
.env.*

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~
.project
.settings/
*.sublime-project
*.sublime-workspace

# OS files
Thumbs.db
Desktop.ini
.DS_Store
.DS_Store?
._*

# Nocturne runtime data (generated locally)
.nocturne_cache/
.nocturne_index/

# Test / coverage
.coverage
htmlcov/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Docker
*.log

# Misc
*.bak
*.tmp
*.temp

# --- secrets (security baseline; do not commit real credentials) ---
.env
.env.*
!.env.example
!.env.*.example
!.env.sample
!.env.secret.example
!.env.local.example
!.env.mesh.example
!.env.prod.example
*.pem
*.key
